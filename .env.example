# Expo Environment Variables Template
# Copy this file to .env and fill in your local values.
# Only variables prefixed with EXPO_PUBLIC_ are exposed to the client-side code.

EXPO_PUBLIC_API_BASE_URL=https://jsonplaceholder.typicode.com
EXPO_PUBLIC_ACCESS_TOKEN_KEY=auth.accessToken
EXPO_PUBLIC_REFRESH_TOKEN_KEY=auth.refreshToken
EXPO_PUBLIC_USER_INFO_KEY=auth.userInfo
